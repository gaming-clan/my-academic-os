{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "An academic course representing a subject",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the course" },
        "userId": { "type": "string", "description": "The UID of the user who owns this course" },
        "name": { "type": "string", "description": "Course name, e.g. Matematikë e Lartë", "maxLength": 100 },
        "code": { "type": "string", "description": "Course code, e.g. MAT201", "maxLength": 20 },
        "instructor": { "type": "string", "description": "Instructor name", "maxLength": 100 },
        "semester": { "type": "string", "description": "Semester information, e.g. Semestri I", "maxLength": 50 },
        "progress": { "type": "integer", "description": "Syllabus progress percentage" },
        "color": { "type": "string", "description": "Aesthetic accent color hex or tailwind class" },
        "credits": { "type": "integer", "description": "Kredite ECTS, used to weight the university-mode overall average" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "An assignment, exam, or project for a course",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the assignment" },
        "userId": { "type": "string", "description": "The UID of the user" },
        "courseId": { "type": "string", "description": "The associated course ID" },
        "title": { "type": "string", "description": "Assignment title", "maxLength": 100 },
        "dueDate": { "type": "string", "format": "date" },
        "weight": { "type": "integer", "description": "Grade weight percentage" },
        "grade": { "type": "number", "description": "Nota achieved, Albanian scale 4 to 10 (optional)" },
        "status": { "type": "string", "enum": ["Pa Filluar", "Në Vazhdim", "Dorëzuar", "Vlerësuar"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "courseId", "title", "weight", "status"]
    },
    "Note": {
      "title": "Note",
      "description": "Academic or lecture note",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the note" },
        "userId": { "type": "string", "description": "The UID of the user" },
        "courseId": { "type": "string", "description": "The associated course ID" },
        "title": { "type": "string", "description": "Note title", "maxLength": 100 },
        "content": { "type": "string", "description": "Markdown text content", "maxLength": 50000 },
        "folder": { "type": "string", "description": "Folder category e.g. Leksione, Laborator, Udhëzues Studimi" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "courseId", "title", "content"]
    },
    "Task": {
      "title": "Task",
      "description": "General task or to-do item",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "userId": { "type": "string", "description": "The UID of the user" },
        "courseId": { "type": "string", "description": "The associated course ID (optional)" },
        "title": { "type": "string", "description": "Task title", "maxLength": 100 },
        "status": { "type": "string", "enum": ["Pa Filluar", "Në Vazhdim", "Përfunduar"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "status"]
    },
    "Profile": {
      "title": "Profile",
      "description": "User's academic profile info",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user" },
        "name": { "type": "string", "description": "Student's name", "maxLength": 100 },
        "program": { "type": "string", "description": "Academic program", "maxLength": 150 },
        "studentId": { "type": "string", "description": "Student identification number", "maxLength": 50 },
        "group": { "type": "string", "description": "Student study group/class", "maxLength": 50 },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    }
  },
  "firestore": {
    "courses/{courseId}": {
      "schema": "Course",
      "description": "User's courses"
    },
    "assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "User's course assignments"
    },
    "notes/{noteId}": {
      "schema": "Note",
      "description": "User's study notes"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "User's personal to-do tasks"
    },
    "profiles/{profileId}": {
      "schema": "Profile",
      "description": "User's personal study profile"
    }
  }
}
