rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation functions
    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'userId', 'name'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (!('code' in data) || (data.code is string && data.code.size() <= 20))
        && (!('instructor' in data) || (data.instructor is string && data.instructor.size() <= 100))
        && (!('semester' in data) || (data.semester is string && data.semester.size() <= 50))
        && (!('progress' in data) || (data.progress is int && data.progress >= 0 && data.progress <= 100))
        && (!('color' in data) || (data.color is string && data.color.size() <= 30))
        && (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['id', 'userId', 'courseId', 'title', 'weight', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.courseId is string && data.courseId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.weight is int && data.weight >= 0 && data.weight <= 100
        && data.status is string && data.status in ['Not Started', 'In Progress', 'Submitted', 'Graded']
        && (!('grade' in data) || (data.grade is int && data.grade >= 0 && data.grade <= 100))
        && (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() <= 30))
        && (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'userId', 'courseId', 'title', 'content'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.courseId is string && data.courseId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.content is string && data.content.size() <= 50000
        && (!('folder' in data) || (data.folder is string && data.folder.size() <= 50))
        && (!('createdAt' in data) || data.createdAt is string)
        && (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.status is string && data.status in ['Not Started', 'In Progress', 'Completed']
        && (!('courseId' in data) || (data.courseId is string && data.courseId.size() <= 128))
        && (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() <= 30))
        && (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['userId', 'name'])
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (!('program' in data) || (data.program is string && data.program.size() <= 150))
        && (!('studentId' in data) || (data.studentId is string && data.studentId.size() <= 50))
        && (!('group' in data) || (data.group is string && data.group.size() <= 50))
        && (!('updatedAt' in data) || data.updatedAt is string);
    }

    // Collection matches

    // COURSES
    match /courses/{courseId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(courseId)
        && isOwner(incoming().userId)
        && isValidCourse(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && isValidCourse(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['name', 'code', 'instructor', 'semester', 'progress', 'color']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // ASSIGNMENTS
    match /assignments/{assignmentId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(assignmentId)
        && isOwner(incoming().userId)
        && isValidAssignment(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && isValidAssignment(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['title', 'courseId', 'dueDate', 'weight', 'grade', 'status']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // NOTES
    match /notes/{noteId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(noteId)
        && isOwner(incoming().userId)
        && isValidNote(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && isValidNote(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['title', 'courseId', 'content', 'folder', 'updatedAt']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // TASKS
    match /tasks/{taskId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(taskId)
        && isOwner(incoming().userId)
        && isValidTask(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && isValidTask(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['title', 'status', 'courseId', 'dueDate']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // PROFILES
    match /profiles/{profileId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(profileId)
        && isOwner(incoming().userId)
        && isValidProfile(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && isValidProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['name', 'program', 'studentId', 'group', 'updatedAt']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
